# ── Kinderboard-Migration (altes MySQL-System) ──────────────────────────────
# Kopiere diese Datei nach .env.local und trage die Zugangsdaten ein.
# .env.local wird NIE eingecheckt (steht in .gitignore).

OLD_KINDERBOARD_DB_HOST=localhost
OLD_KINDERBOARD_DB_USER=kinderboard
OLD_KINDERBOARD_DB_PASS=
OLD_KINDERBOARD_DB_NAME=kinderboard

# ── Lizenz-Tier-Enforcement (Phase 2, siehe LICENSE_TIERS.md) ───────────────
# false/unset (Standard): Navigation zeigt alle Module unabhängig vom
#   benötigten Lizenz-Tier — bestehende lokale Nutzung bleibt unverändert.
# true: PREMIUM-/UNLIMITED-Module werden für COMMUNITY-Nutzer in der
#   Navigation ausgeblendet (getNavModulesForRole() filtert nach Tier).
#   MUSS vor dem Public Release auf true gesetzt werden.
# Build-time Flag (NEXT_PUBLIC_, da in Client-Komponenten ausgewertet) —
# nach Änderung `npm run build` erneut ausführen.
NEXT_PUBLIC_ENABLE_TIER_ENFORCEMENT=false
